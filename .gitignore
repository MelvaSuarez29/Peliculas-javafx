cat > .gitignore << "EOF"
# Archivos compilados de Java
*.class
*.jar
*.war
*.ear

# Carpetas de salida de compilación
target/
out/
build/
bin/
dist/

# Archivos de configuración de IDE (IntelliJ IDEA)
.idea/
*.iml
*.iws
*.ipr
out/

# Archivos de configuración de Eclipse
.settings/
.classpath
.project
.metadata/

# Archivos de configuración de VS Code
.vscode/
*.code-workspace

# Archivos de logs
*.log

# Archivos de sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Archivos de base de datos locales (si los hay)
*.db
*.sqlite

# Archivos de propiedades con credenciales (¡seguridad!)
config.properties
application.properties
database.properties

# Archivos temporales de Maven/Gradle
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Archivos temporales de Gradle
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# Archivos de cobertura de código
*.coverage
*.hprof

# Archivos de Spring Boot (si usas)
springboot.*
EOF